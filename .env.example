# Application
NODE_ENV=development

# Supabase PostgreSQL — pooled connection (port 6543, ?pgbouncer=true)
# Used by the Next.js app and Prisma Client at runtime (Vercel / serverless).
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase PostgreSQL — direct connection (port 5432)
# Used by Prisma CLI for db push, migrate, and introspect (not used at app runtime).
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres"

# Upstash Redis (recommended for production idempotency)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Idempotency cache TTL in seconds (default: 86400 / 24h)
IDEMPOTENCY_TTL_SECONDS="86400"

# CI / build without live services
# SKIP_ENV_VALIDATION=true
